{
  "name": "pubifact-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "bucket": "wrangler r2 bucket create pubifact",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "types": "wrangler types --include-env=false",
    "typecheck": "npm run types && tsc --noEmit",
    "test": "vitest run",
    "check": "npm run lint && npm run typecheck && npm test"
  },
  "dependencies": {
    "marked": "^14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3",
    "@cloudflare/vitest-pool-workers": "^0.16",
    "typescript": "^5",
    "vitest": "^4.1",
    "wrangler": "^4"
  }
}
